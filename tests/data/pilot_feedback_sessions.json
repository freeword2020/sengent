        "expected_reused_anchor": true
      }
    ]
  },
  {
    "id": "parameter-then-doc-reset",
    "source": "interactive-trial",
    "turns": [
      {
        "prompt": "DNAscope 的 --pcr_free 是什么",
        "expected_mode": "parameter",
